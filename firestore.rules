rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isNasabahOwner(nasabahId) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.nasabah_id == nasabahId)
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles rules
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Nasabah rules
    match /nasabah/{nasabahId} {
      allow read: if isNasabahOwner(nasabahId);
      allow write: if isAdmin();
      
      match /history/{angsuranId} {
        allow read: if isNasabahOwner(nasabahId);
        allow write: if isAdmin();
      }
    }

    // Keuangan rules
    match /keuangan/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
